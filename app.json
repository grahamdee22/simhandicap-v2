{
  "expo": {
    "name": "SimCap",
    "slug": "simhandicap-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "simcap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3a2a"
    },
    "ios": {
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:app.sim-cap.com",
        "applinks:app.sim-cap.com",
        "applinks:app.sim-cap.com",
        "applinks:app.sim-cap.com"
      ],
      "bundleIdentifier": "com.simcap.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "simcap",
              "host": "reset-password"
            },
            {
              "scheme": "https",
              "host": "app.sim-cap.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "simcap",
              "host": "reset-password"
            },
            {
              "scheme": "https",
              "host": "app.sim-cap.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.simcap.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "SimCap",
      "shortName": "SimCap",
      "description": "The GHIN for simulator golf",
      "themeColor": "#1a3a2a",
      "backgroundColor": "#1a3a2a",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "39ea49ed-98b0-411c-8570-22c8c6284769"
      }
    },
    "owner": "grahamdee22"
  }
}
